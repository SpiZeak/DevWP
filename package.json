{
  "name": "devwp",
  "version": "0.2.7",
  "description": "A Tauri application with React and TypeScript for managing WordPress development environments.",
  "author": "Trewhitt",
  "homepage": "https://trewhitt.au",
  "scripts": {
    "build": "bun run --bun typecheck && bun run --bun build:web",
    "build:tauri": "bun run --bun typecheck && bun run --bun build:web && tauri build",
    "build:web": "vite build --config vite.config.ts",
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.ts",
    "format": "biome format --write",
    "lint": "biome lint",
    "start": "vite preview --config vite.config.ts",
    "test": "vitest",
    "test:all": "bun run --bun test:run && bun run --bun test:integration",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "bun run --bun typecheck:node && bun run --bun typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "dependencies": {
    "@colors/colors": "^1.6.0",
    "@dabh/diagnostics": "^2.0.8",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-log": "~2",
    "@tauri-apps/plugin-opener": "~2",
    "async": "^3.2.6",
    "fecha": "^4.2.3",
    "inherits": "^2.0.4",
    "is-stream": "^4.0.1",
    "logform": "^2.7.0",
    "one-time": "^1.0.0",
    "readable-stream": "^4.7.0",
    "safe-stable-stringify": "^2.5.0",
    "simple-icons": "^16.18.1",
    "stack-trace": "^1.0.0",
    "sudo-prompt": "^9.2.1",
    "tailwindcss": "^4.2.4",
    "triple-beam": "^1.4.1",
    "util-deprecate": "^1.0.2",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "winston-transport": "^4.9.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
