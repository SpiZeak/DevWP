{
  "name": "devwp",
  "version": "0.3.3",
  "description": "A Tauri application with React and TypeScript for managing WordPress development environments.",
  "author": "Trewhitt",
  "homepage": "https://trewhitt.au",
  "scripts": {
    "build": "bun run --bun typecheck && bun run --bun build:web",
    "build:tauri": "bun run --bun typecheck && bun run --bun build:web && tauri build",
    "build:web": "vite build --config vite.config.ts",
    "dev": "tauri dev",
    "dev:web": "vite --config vite.config.ts",
    "format": "biome format --write",
    "lint": "biome lint",
    "start": "vite preview --config vite.config.ts",
    "test": "vitest",
    "test:all": "bun run --bun test:run && bun run --bun test:integration",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:integration:watch": "vitest --config vitest.config.integration.ts",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "typecheck": "bun run --bun typecheck:node && bun run --bun typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-log": "~2",
    "@tauri-apps/plugin-opener": "~2",
    "simple-icons": "^16.27.0",
    "sudo-prompt": "^9.2.1",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
