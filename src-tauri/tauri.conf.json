{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevWP",
  "version": "0.1.1",
  "identifier": "com.devwp.app",
  "build": {
    "beforeDevCommand": "bun run dev:web",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevWP",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
