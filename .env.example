# DevWP Environment Configuration
# Copy this file to .env and configure your environment variables
# Usage: cp .env.example .env

# ============================================
# Docker Environment
# ============================================
# Set these to match your host user/group IDs to avoid permission issues
# Find your UID: id -u
# Find your GID: id -g
# UID=1000
# GID=1000

# ============================================
# Development Settings
# ============================================
# Set to 'development' for debug logs, 'production' for production
NODE_ENV=development

# ============================================
# Logging Configuration
# ============================================
# Log level: error, warn, info, http, debug
LOG_LEVEL=info

# Maximum log file age in days
LOG_MAX_FILES=14

# ============================================
# Security Settings
# ============================================
# Enable/disable automatic updates check
AUTO_UPDATE_CHECK=true

# Enable/disable crash reporting (if implemented)
# CRASH_REPORTING=false
